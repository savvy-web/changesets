{
	"name": "changesets",
	"version": "0.0.0",
	"private": true,
	"description": "Custom changelog formatter and markdown processing pipeline for the Silk Suite. Provides structured changeset sections, remark-based validation and transformation, and an Effect CLI.",
	"homepage": "https://github.com/savvy-web/changesets#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/changesets/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/changesets.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"scripts": {
		"build": "turbo run build:dev build:prod --log-order=grouped",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" vitest run --coverage",
		"ci:version": "npx tsx src/bin/cli.ts version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"postprepare": "turbo run build:dev build:prod --output-logs=errors-only --log-order=grouped",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@savvy-web/commitlint": "^0.4.3",
		"@savvy-web/lint-staged": "^0.6.2",
		"@savvy-web/rslib-builder": "^0.19.0",
		"@savvy-web/changesets": "workspace:*",
		"@savvy-web/vitest": "^1.0.0"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"engines": {
		"node": ">=24.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "10.32.1",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "24.11.0",
				"onFail": "ignore"
			}
		]
	}
}
