{
	"name": "@savvy-web/changesets",
	"version": "0.7.5",
	"private": true,
	"description": "Custom changelog formatter and markdown processing pipeline for the Silk Suite. Provides structured changeset sections, remark-based validation and transformation, and an Effect CLI.",
	"keywords": ["changesets", "changelog", "release-notes", "remark", "markdown", "effect", "silk-suite"],
	"homepage": "https://github.com/savvy-web/changesets/package#readme",
	"bugs": {
		"url": "https://github.com/savvy-web/changesets/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/savvy-web/changesets.git",
		"directory": "package"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./changelog": "./src/changelog/index.ts",
		"./markdownlint": "./src/markdownlint/index.ts",
		"./remark": "./src/remark/index.ts"
	},
	"bin": {
		"savvy-changesets": "./src/bin/cli.ts"
	},
	"scripts": {
		"build": "turbo run build:dev build:prod",
		"build:dev": "rslib build --config-loader native --env-mode dev",
		"build:prod": "rslib build --config-loader native --env-mode npm",
		"prepare": "rslib build --config-loader native --env-mode dev",
		"types:check": "tsgo --noEmit"
	},
	"dependencies": {
		"@changesets/get-github-info": "^0.8.0",
		"@effect/cli": "catalog:silk",
		"@effect/platform": "catalog:silk",
		"@effect/platform-node": "catalog:silk",
		"@savvy-web/silk-effects": "^0.2.2",
		"effect": "catalog:silk",
		"jsonc-effect": "^0.2.1",
		"mdast-util-heading-range": "^4.0.0",
		"mdast-util-to-string": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-stringify": "^11.0.0",
		"tinyglobby": "^0.2.15",
		"unified": "^11.0.5",
		"unified-lint-rule": "^3.0.1",
		"unist-util-visit": "^5.1.0",
		"workspaces-effect": "^0.3.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@changesets/types": "^6.1.0",
		"@microsoft/api-extractor": "^7.57.7",
		"@rslib/core": "0.20.0",
		"@savvy-web/rslib-builder": "^0.20.0",
		"@types/mdast": "^4.0.4",
		"@types/node": "catalog:silk",
		"@typescript/native-preview": "catalog:silk",
		"markdownlint": "^0.40.0",
		"typescript": "catalog:silk"
	},
	"peerDependencies": {
		"@changesets/cli": "^2.30.0"
	},
	"peerDependenciesMeta": {
		"@changesets/cli": {
			"optional": false
		}
	},
	"engines": {
		"node": ">=24.0.0"
	},
	"publishConfig": {
		"access": "public",
		"directory": "dist/dev",
		"linkDirectory": true,
		"targets": [
			{
				"protocol": "npm",
				"registry": "https://npm.pkg.github.com/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			},
			{
				"protocol": "npm",
				"registry": "https://registry.npmjs.org/",
				"directory": "dist/npm",
				"access": "public",
				"provenance": true
			}
		]
	}
}
